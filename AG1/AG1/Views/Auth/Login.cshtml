@model AG1.Models.LoginViewModel
@{ Layout = "_Layout"; ViewData["Title"] = "Connexion"; }

<div class="login-page">
    <div class="login-card">
        <div class="login-brand">AG<em>1</em></div>
        <p class="login-sub">Gestion des Stocks · Portail Vendeurs</p>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-error">
                @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                { <span>@error.ErrorMessage</span> }
            </div>
        }

        <form asp-action="Login" method="post">
            @Html.AntiForgeryToken()
            <div class="form-group">
                <label>Email</label>
                <input asp-for="Email" type="email" placeholder="votre@email.com" autocomplete="email" />
                <span asp-validation-for="Email" class="validation-error"></span>
            </div>
            <div class="form-group">
                <label>Mot de passe</label>
                <input asp-for="MotDePasse" type="password" placeholder="••••••••" autocomplete="current-password" />
                <span asp-validation-for="MotDePasse" class="validation-error"></span>
            </div>
            <div class="checkbox-row" style="margin-bottom:20px">
                <input asp-for="RememberMe" type="checkbox" />
                <label asp-for="RememberMe">Se souvenir de moi (8h → 24h)</label>
            </div>
            <button type="submit" class="btn-login">Se connecter →</button>
        </form>
    </div>
</div>
