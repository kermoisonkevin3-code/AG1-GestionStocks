<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] – AG1 Gestion Stocks</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
    <!-- Bootstrap 5.3 – Critère 4 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/ag1.css" asp-append-version="true">
</head>
<body>

@if (User.Identity?.IsAuthenticated == true)
{
<div class="app-shell">
    <!-- SIDEBAR -->
    <aside class="sidebar">
        <div class="sidebar-brand">
            <span class="brand-logo">AG<em>1</em></span>
            <span class="brand-sub">Gestion Stocks</span>
        </div>

        <nav class="sidebar-nav">
            <a href="@Url.Action("Index","Home")" class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")">
                <span class="nav-icon">⬛</span> Dashboard
            </a>
            <div class="nav-section">Catalogue</div>
            <a href="@Url.Action("Index","Products")" class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Products" ? "active" : "")">
                <span class="nav-icon">📦</span> Produits
            </a>
            <div class="nav-section">Ventes</div>
            <a href="@Url.Action("Index","Orders")" class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Orders" ? "active" : "")">
                <span class="nav-icon">🧾</span> Commandes
            </a>
            <a href="@Url.Action("Clients","Orders")" class="nav-item">
                <span class="nav-icon">👥</span> Clients
            </a>
            @if (User.IsInRole("admin"))
            {
            <div class="nav-section">Administration</div>
            <a href="@Url.Action("Index","Admin")" class="nav-item">
                <span class="nav-icon">⚙</span> Utilisateurs
            </a>
            }
        </nav>

        <div class="sidebar-footer">
            <div class="user-info">
                <div class="user-avatar">@User.Identity.Name?.Substring(0,1).ToUpper()</div>
                <div>
                    <div class="user-name">@User.Identity.Name</div>
                    <div class="user-role">@User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value</div>
                </div>
            </div>
            <a href="@Url.Action("Logout","Auth")" class="btn-logout">Déconnexion</a>
        </div>
    </aside>

    <!-- MAIN -->
    <main class="main-content">
        <div class="topbar">
            <h1 class="page-title">@ViewData["Title"]</h1>
            <div class="topbar-right">
                <span class="topbar-date">@DateTime.Now.ToString("dddd dd MMMM yyyy", new System.Globalization.CultureInfo("fr-FR"))</span>
            </div>
        </div>

        @if (TempData["Success"] != null)
        {
        <!-- Bootstrap alert – Critère 4 -->
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
        }
        @if (TempData["Error"] != null)
        {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
        }
        @if (TempData["Warning"] != null)
        {
        <div class="alert alert-warning alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-circle-fill me-2"></i>@TempData["Warning"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
        }

        <div class="content-area">
            @RenderBody()
        </div>
    </main>
</div>
}
else
{
    @RenderBody()
}

<!-- Bootstrap JS – Critère 4 -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/ag1.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
